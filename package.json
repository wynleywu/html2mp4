{
  "name": "html2mp4",
  "productName": "HTML2MP4",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "electron electron/main.cjs",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:4001 && electron electron/main.cjs\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "package": "node scripts/pack.cjs"
  },
  "build": {
    "appId": "com.html2mp4.app",
    "productName": "HTML2MP4",
    "directories": {
      "output": "dist_app"
    },
    "files": [
      "electron/**/*",
      "engine/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "electronDist": "node_modules/electron/dist",
    "asar": false,
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "ws": "^8.20.0"
  }
}
